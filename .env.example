# ================================
# Lembayung Configuration
# ================================

# Target Resource (Required)
TARGET_ID=1234
TARGET_SLUG=target-venue
PROVIDER_API_KEY=your-api-key-here
PROVIDER_BASE_URL=https://api.booking-provider.com/v2
PROVIDER_ORIGIN=https://reservation.provider.com
PROVIDER_REFERER=https://reservation.provider.com/

# ================================
# Monitoring Preferences
# ================================

# Pax to monitor (Set MIN and MAX to the same number for one specific count)
MIN_PAX=4
MAX_PAX=4

# Time range filter (24h format). Leave empty to monitor all times.
TIME_RANGE_START=18:00
TIME_RANGE_END=22:00

# Day filter options:
#   "everyday"   - monitor all days
#   "weekdays"   - mon through fri
#   "weekends"   - sat and sun only
#   "mon,fri"    - specific days (comma-separated, lowercase)
DAY_FILTER=weekends

# How many days ahead to scan (Higher values increase rate-limiting risk)
FETCH_DAYS_AHEAD=14

# Polling interval in seconds (minimum recommended: 300)
POLL_INTERVAL_SECONDS=300

# ================================
# Notifications (provide at least one)
# ================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=

# ================================
# System
# ================================
SQLITE_DB_PATH=./lembayung_state.db
ENABLE_AUTO_BOOKING=False
DRY_RUN=True

# ================================
# Rate-Limiting Safety
# ================================
# Randomized delay between requests (seconds)
REQUEST_DELAY_MIN=3.0
REQUEST_DELAY_MAX=6.0
# Longer pause every N requests
BATCH_COOLDOWN_EVERY=3
BATCH_COOLDOWN_SECONDS=15.0
